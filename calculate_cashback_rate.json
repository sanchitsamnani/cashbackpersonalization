        "pythonCode": "average_revenue = items[0].json[\"average_revenue\"]\nrevenue_decrease_tolerance_percentage = items[0].json[\"revenue_decrease_tolerance_percentage\"]\nretailer_list = list(map(lambda clean_item: clean_item.json, items[1:]))\nreturn {\"average_revenue\": average_revenue, \"revenue_decrease_tolerance_percentage\": revenue_decrease_tolerance_percentage, \"retailer_list\": retailer_list}"
