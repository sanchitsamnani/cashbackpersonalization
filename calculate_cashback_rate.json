    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst systemPrompt = input.prediction_commission_system_prompt;\nconst userPrompt = input.prediction_commission_user_prompt;\nconst atollsCashback = input.atolls_cashback;\nconst competitorList = input.competitor_cashback_list;\n\nconst cashbackData = {\n  atolls_cashback: atollsCashback,\n  competitor_cashback_list: competitorList\n};\n\nconst cashbackDataString = JSON.stringify(cashbackData, null, 2);\n\nconst updatedUserContent = userPrompt.content.replace(\n  \"{{cashback_data}}\",\n  cashbackDataString\n);\n\nreturn [\n  {\n    json: {\n      prediction_commission_system_prompt: systemPrompt,\n      prediction_commission_user_prompt: {\n        ...userPrompt,\n        content: updatedUserContent\n      }\n    }\n  }\n];\n"
      },
