    {
      "parameters": {
        "language": "python",
        "pythonCode": "import json\n\nprediction_commission_user_prompt = _input.first().json.prediction_commission_user_prompt\ncashback_data = {\"atolls_cashback\": _input.first().json.atolls_cashback, \"competitor_cashback_list\": _input.first().json.competitor_cashback_list}\nprediction_commission_user_prompt.content = prediction_commission_user_prompt.content.replace(\"{{cashback_data}}\", json.dumps(cashback_data))\nreturn {\"prediction_commission_system_prompt\": _input.first().json.prediction_commission_system_prompt, \"prediction_commission_user_prompt\": cashback_data}"
