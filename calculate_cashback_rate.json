      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    *\nFROM (\n    SELECT\n        *,\n        ROW_NUMBER() OVER (\n            PARTITION BY retailer_name, name\n            ORDER BY created_at DESC\n        ) AS rn\n    FROM competitor\n) t\nWHERE rn = 1;",
        "options": {}
